# TMDB API Key (required for Vercel deployments)
# Get your free API key at: https://www.themoviedb.org/settings/api
VITE_TMDB_API_KEY=your_tmdb_api_key_here

# Supabase credentials (optional - only needed for Supabase Edge Function fallback)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Custom video embed source base URL
# If you have a working embed service, set its base URL here.
# Format: https://your-source.com (no trailing slash)
# The app will use: {VITE_CUSTOM_EMBED_URL}/embed/movie/{id} and /embed/tv/{id}/{season}/{episode}
# If left empty, a default fallback source will be used.
VITE_CUSTOM_EMBED_URL=
